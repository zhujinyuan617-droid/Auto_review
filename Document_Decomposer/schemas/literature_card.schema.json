{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LiteratureCard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "paper_id",
    "paper",
    "classification",
    "fuzzy_keywords",
    "core_question",
    "study_design",
    "variables",
    "mechanisms",
    "key_findings",
    "quantitative_results",
    "limitations",
    "review_section_hints",
    "ai_warnings"
  ],
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reading_block_id",
        "source_block_ids",
        "page_start",
        "page_end",
        "quote",
        "note"
      ],
      "properties": {
        "reading_block_id": {
          "type": "string",
          "pattern": "^S\\d+-RB-\\d{4}$"
        },
        "source_block_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^S\\d+-BLK-\\d{4}$"
          }
        },
        "page_start": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "page_end": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "quote": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "evidence_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "paper_id": {
      "type": "string",
      "pattern": "^S\\d+$"
    },
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "doi", "year", "journal", "paper_type"],
      "properties": {
        "title": {
          "type": "string"
        },
        "doi": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "journal": {
          "type": "string"
        },
        "paper_type": {
          "type": "string",
          "enum": ["experimental", "simulation", "review", "hybrid", "other", "unknown"]
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_objects", "gas_systems", "methods", "scale", "domain_tags"],
      "properties": {
        "research_objects": {
          "$ref": "#/$defs/string_array"
        },
        "gas_systems": {
          "$ref": "#/$defs/string_array"
        },
        "methods": {
          "$ref": "#/$defs/string_array"
        },
        "scale": {
          "$ref": "#/$defs/string_array"
        },
        "domain_tags": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "fuzzy_keywords": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyword", "reason", "evidence"],
        "properties": {
          "keyword": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "core_question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "evidence"],
      "properties": {
        "claim": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidence_array"
        }
      }
    },
    "study_design": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["aspect", "detail", "evidence"],
        "properties": {
          "aspect": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "values_or_range", "evidence"],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["independent", "dependent", "control", "condition", "parameter", "other", "unknown"]
          },
          "values_or_range": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "mechanisms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mechanism", "explanation", "evidence"],
        "properties": {
          "mechanism": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "evidence"],
        "properties": {
          "claim": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "quantitative_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metric", "value", "condition", "interpretation", "evidence"],
        "properties": {
          "metric": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          },
          "interpretation": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["limitation", "evidence"],
        "properties": {
          "limitation": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "review_section_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section", "reason", "evidence"],
        "properties": {
          "section": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidence_array"
          }
        }
      }
    },
    "ai_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
